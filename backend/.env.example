# Path to the Google OAuth Desktop client_secret.json (gitignored under secrets/)
GOOGLE_CLIENT_SECRET_FILE=./secrets/client_secret.json

# Where to persist the YouTube refresh token after `node connect-youtube.js`
YT_TOKEN_FILE=./secrets/yt_token.json

# YouTube Data API v3 key (used for read/list operations only; uploads use OAuth)
YOUTUBE_API_KEY=

# Default upload privacy: private | unlisted | public
DEFAULT_PRIVACY=private

# ---------- Meta / Facebook ----------
# From Meta for Developers -> App settings -> Basic
FB_APP_ID=
FB_APP_SECRET=

# OAuth loopback redirect. Must EXACTLY match the URI added in Meta:
#   Use cases -> Authentication and account creation -> Settings -> Valid OAuth Redirect URIs
# We use port 3100 so it doesn't clash with the Next.js dev server on 3000.
FB_REDIRECT_URI=http://localhost:3100/oauth/facebook/callback

# Graph API version pinned for reproducibility
FB_API_VERSION=v21.0

# Where to persist Facebook long-lived user token + per-Page tokens
FB_TOKEN_FILE=./secrets/fb_token.json
